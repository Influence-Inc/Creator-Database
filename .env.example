# ---------------------------------------------------------------------------
# Creator Database Backend — environment variables
# Copy to `.env` and fill in the blanks for local development.
# On Railway, set these in the service "Variables" tab instead.
# ---------------------------------------------------------------------------

# --- Server ----------------------------------------------------------------
# Port the HTTP server listens on. Railway injects PORT automatically.
PORT=3000
# Node environment: development | production | test
NODE_ENV=development
# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
# Railway sets this automatically (e.g. "production"). Used only for diagnostics.
RAILWAY_ENVIRONMENT=

# --- Database --------------------------------------------------------------
# Postgres connection string. Railway's Postgres plugin exposes DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/creator_database?schema=public

# --- Internal API auth -----------------------------------------------------
# Shared secret that protects mutating endpoints (POST/PATCH/PUT/DELETE). The
# Outreach backend sends it as the `x-api-key` header when syncing signed
# contracts (its CREATOR_DB_API_KEY must match this value). Read endpoints and
# the health check stay open regardless.
#
# STRONGLY RECOMMENDED in production. If unset, the service still boots (so a
# fresh Railway deploy doesn't fail on missing config) but every mutating
# request goes through UNAUTHENTICATED with a warning in the logs. Set this
# value to enforce authentication on writes.
INTERNAL_API_KEY=

# --- Admin console auth ----------------------------------------------------
# Sign-in for the admin UI (served at /). When ADMIN_PASSWORD is set, the console
# requires sign-in AND read endpoints (GET) require either a valid admin session
# or the x-api-key. When it's blank, the UI + reads stay open (dev/test) with a
# startup warning — set a password to enforce authentication.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Secret used to sign session cookies. Defaults to INTERNAL_API_KEY, then a
# per-boot random value (sessions then reset on restart / don't span replicas).
# Set a stable random string in production (e.g. `openssl rand -hex 32`).
AUTH_SESSION_SECRET=
# Session lifetime in hours (how long a sign-in stays valid).
AUTH_SESSION_TTL_HOURS=12

# --- Instantly (outreach dashboard + email threads) ------------------------
# API key from https://app.instantly.ai/app/settings/integrations
INSTANTLY_API_KEY=
# Base URL for the Instantly v2 API. Override only for testing/mocking.
INSTANTLY_API_BASE=https://api.instantly.ai/api/v2
# Per-request timeout for Instantly calls, in milliseconds.
INSTANTLY_TIMEOUT_MS=15000
# Optional: restrict outreach + email sync to a comma-separated list of
# Instantly campaign UUIDs. Leave blank to sync every campaign in the workspace.
INSTANTLY_CAMPAIGN_IDS=
# Optional: restrict email sync to a single connected mailbox (eaccount),
# e.g. jennifer@useinfluence.xyz. Leave blank to read all mailboxes.
INSTANTLY_EACCOUNT=

# --- influence-stats / ReelMetrics (performance + risk + CPM) ---------------
# Base URL of the influence-stats service (a.k.a. campaign.influence.technology).
# On Railway use the internal DNS name, e.g. http://influence-stats.railway.internal:PORT.
# Leave blank to DISABLE the stats sync job entirely (nothing is polled).
STATS_API_URL=
# Shared secret sent as the `x-bot-token` header; must equal influence-stats' BOT_TOKEN.
STATS_BOT_TOKEN=
# Per-request timeout for stats calls, in milliseconds.
STATS_TIMEOUT_MS=20000

# --- Claude (Anthropic) ----------------------------------------------------
# API key from https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=
# Model used for structured extraction. Defaults to the latest Opus.
# Cost-sensitive deployments can switch to claude-haiku-4-5 or claude-sonnet-5.
CLAUDE_MODEL=claude-opus-4-8
# Max output tokens for each extraction call (the JSON payload is small).
CLAUDE_MAX_TOKENS=1500
# Retry attempts for transient Claude failures before dead-lettering.
CLAUDE_MAX_RETRIES=3

# --- Background jobs / scheduler -------------------------------------------
# Master switch for cron jobs. Set to false to run the API without workers
# (e.g. when running a separate worker process, or during tests).
ENABLE_SCHEDULER=true
# Cron expressions for each background job (standard 5-field cron).
# Job 1: sync outreach dashboard (default: every 30 minutes)
CRON_OUTREACH_SYNC=*/30 * * * *
# Job 2: sync latest email threads (default: every 10 minutes)
CRON_EMAIL_SYNC=*/10 * * * *
# Job 3: run Claude extraction for new/edited threads (default: every 10 minutes)
CRON_CLAUDE_EXTRACTION=*/10 * * * *
# Job 4: sync creator performance/risk/CPM from influence-stats (default: every 30 minutes)
CRON_STATS_SYNC=*/30 * * * *
# How many days back to look when deciding which deadlines are "upcoming".
UPCOMING_DEADLINE_DAYS=30

# --- Seeding ---------------------------------------------------------------
# The demo seed (prisma/seed.ts) is opt-in so it can never add placeholder
# creators to a real database. Set to "true" only for local demos, then run
# `npm run db:seed`. Leave unset in production.
SEED_DEMO=
