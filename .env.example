# ---------------------------------------------------------------------------
# Creator Database Backend — environment variables
# Copy to `.env` and fill in the blanks for local development.
# On Railway, set these in the service "Variables" tab instead.
# ---------------------------------------------------------------------------

# --- Server ----------------------------------------------------------------
# Port the HTTP server listens on. Railway injects PORT automatically.
PORT=3000
# Node environment: development | production | test
NODE_ENV=development
# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
# Railway sets this automatically (e.g. "production"). Used only for diagnostics.
RAILWAY_ENVIRONMENT=

# --- Database --------------------------------------------------------------
# Postgres connection string. Railway's Postgres plugin exposes DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/creator_database?schema=public

# --- Instantly (outreach dashboard + email threads) ------------------------
# API key from https://app.instantly.ai/app/settings/integrations
INSTANTLY_API_KEY=
# Base URL for the Instantly v2 API. Override only for testing/mocking.
INSTANTLY_API_BASE=https://api.instantly.ai/api/v2
# Per-request timeout for Instantly calls, in milliseconds.
INSTANTLY_TIMEOUT_MS=15000
# Optional: restrict outreach + email sync to a comma-separated list of
# Instantly campaign UUIDs. Leave blank to sync every campaign in the workspace.
INSTANTLY_CAMPAIGN_IDS=
# Optional: restrict email sync to a single connected mailbox (eaccount),
# e.g. jennifer@useinfluence.xyz. Leave blank to read all mailboxes.
INSTANTLY_EACCOUNT=

# --- Claude (Anthropic) ----------------------------------------------------
# API key from https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=
# Model used for structured extraction. Defaults to the latest Opus.
# Cost-sensitive deployments can switch to claude-haiku-4-5 or claude-sonnet-5.
CLAUDE_MODEL=claude-opus-4-8
# Max output tokens for each extraction call (the JSON payload is small).
CLAUDE_MAX_TOKENS=1500
# Retry attempts for transient Claude failures before dead-lettering.
CLAUDE_MAX_RETRIES=3

# --- Background jobs / scheduler -------------------------------------------
# Master switch for cron jobs. Set to false to run the API without workers
# (e.g. when running a separate worker process, or during tests).
ENABLE_SCHEDULER=true
# Cron expressions for each background job (standard 5-field cron).
# Job 1: sync outreach dashboard (default: every 30 minutes)
CRON_OUTREACH_SYNC=*/30 * * * *
# Job 2: sync latest email threads (default: every 10 minutes)
CRON_EMAIL_SYNC=*/10 * * * *
# Job 3: run Claude extraction for new/edited threads (default: every 10 minutes)
CRON_CLAUDE_EXTRACTION=*/10 * * * *
# How many days back to look when deciding which deadlines are "upcoming".
UPCOMING_DEADLINE_DAYS=30
